GOOGLE_API_KEY=your_google_api_key_here
DB_USER=knowledge_user
DB_PASSWORD=replace_with_strong_db_password
DB_NAME=knowledge_db
DB_HOST=/var/run/postgresql
EMBEDDING_MODEL=google/text-embedding-004
GENERATION_MODEL=google/gemini-flash-latest
AUTH_SECRET_KEY=replace_with_at_least_32_chars_secret
AUTH_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
RAG_TABLE_NAME=knowledge_base
RAG_CONTENT_COLUMN=content
RAG_SOURCE_COLUMN=file_path
RAG_EMBEDDING_COLUMN=embedding
RAG_METADATA_COLUMN=metadata
RAG_VECTOR_DIM=768
RAG_SIMILARITY_METRIC=cosine
UPLOAD_DIR=data/uploads
UPLOAD_MAX_BYTES=20971520
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
LOGIN_RATE_LIMIT_PER_MINUTE=10
CHAT_RATE_LIMIT_PER_MINUTE=60
ENABLE_INDEXING_WORKER=true
LOG_LEVEL=INFO

